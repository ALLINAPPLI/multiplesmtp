<?php

class CRM_Multiplesmtp_HookTMP {

  /**
   * Clé de préfixe pour les settings CiviCRM
   */
  const SETTING_PREFIX = 'multiplesmtp_';

  // -------------------------------------------------------
  // Champs à ajouter sur la page SMTP
  // -------------------------------------------------------
  private static $fields = [
    'smtp_server'   => ['label' => 'Serveur SMTP transactionnel', 'type' => 'text'],
    'smtp_port'     => ['label' => 'Port SMTP transactionnel',    'type' => 'text'],
    'smtp_auth'     => ['label' => 'Authentification requise',    'type' => 'checkbox'],
    'smtp_username' => ['label' => 'Nom d\'utilisateur SMTP',     'type' => 'text'],
    'smtp_password' => ['label' => 'Mot de passe SMTP',           'type' => 'password'],
  ];

  // -------------------------------------------------------
  // 1. Injection des champs dans la page
  // -------------------------------------------------------
  // public static function buildForm($formName, &$form) {
  //   // On cible uniquement la page de config SMTP
  //   if ($formName !== 'CRM_Admin_Form_Setting_Smtp') {
